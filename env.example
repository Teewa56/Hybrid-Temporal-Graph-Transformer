# ── neobank API ──────────────────────────────────────────────────
neobank_SECRET_KEY=sk_test_your_neobank_secret_key_here
neobank_BASE_URL=https://sandbox-api-d.neobankco.com
NEOBANK_WEBHOOK_SECRET=your_webhook_signing_secret_here

# ── Neo4j ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Model Serving ──────────────────────────────────────────────
MODEL_QUANTIZATION=onnx                  # onnx | tensorrt | none
INFERENCE_TIMEOUT_MS=200
CHECKPOINT_DIR=checkpoints/

# ── Decision Engine Thresholds ──────────────────────────────────
GREEN_THRESHOLD=0.65
RED_THRESHOLD=0.90

# ── Continual Learning ──────────────────────────────────────────
DRIFT_DELTA=0.002
ACTIVE_LEARNING_QUEUE_SIZE=500
SHADOW_PROMOTION_THRESHOLD=1000
EWC_IMPORTANCE=1000.0

# ── Logging & Audit ─────────────────────────────────────────────
AUDIT_LOG_PATH=logs/audit_trail.jsonl
LOG_LEVEL=INFO

# ── App ────────────────────────────────────────────────────────
ENV=sandbox                              # sandbox | production
PORT=8000